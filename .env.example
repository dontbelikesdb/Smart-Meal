DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/meal_planner
TEST_DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/meal_planner_test
SECRET_KEY=replace-with-a-long-random-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=4320
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
REDIS_URL=redis://localhost:6379
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
OPENAI_API_KEY=
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
LOCAL_TRANSCRIPTION_MODEL=small
LOCAL_TRANSCRIPTION_COMPUTE_TYPE=int8
LOCAL_TRANSCRIPTION_LANGUAGE=en
LOCAL_TRANSCRIPTION_BEAM_SIZE=5
LOCAL_TRANSCRIPTION_VAD_FILTER=false
FIRST_SUPERUSER_EMAIL=admin@example.com
FIRST_SUPERUSER_PASSWORD=choose-a-strong-password
SEED_DEFAULT_ALLERGIES=true
SEED_DEFAULT_ALLERGIES_AUTOMAP_LIMIT=25
